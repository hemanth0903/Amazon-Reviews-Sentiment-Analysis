{
  "datasets": [
    {
      "name": "f546b138",
      "displayName": "Home & Kitchen - KPI Summary dataset",
      "config": {
        "version": "1.1",
        "source": "SELECT\r\n  COUNT(*) AS total_reviews,\r\n  ROUND(AVG(rating), 2) AS avg_rating,\r\n  ROUND(AVG(helpful_vote), 2) AS avg_helpful_votes\r\nFROM workspace.default.home_kitchen_reviews_clean_sample",
        "dimensions": [
          {
            "name": "total_reviews",
            "expr": "source.total_reviews",
            "displayName": "Total Reviews"
          },
          {
            "name": "avg_rating",
            "expr": "source.avg_rating",
            "displayName": "Avg Rating"
          },
          {
            "name": "avg_helpful_votes",
            "expr": "source.avg_helpful_votes",
            "displayName": "Avg Helpful Votes"
          }
        ],
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset. Use this measure to count all",
            "displayName": "Count"
          }
        ]
      }
    },
    {
      "name": "a35e4b5a",
      "displayName": "Home & Kitchen - Verified Purchase dataset",
      "config": {
        "version": "1.1",
        "source": "SELECT\r\n  verified_purchase,\r\n  COUNT(*) AS review_count,\r\n  ROUND(AVG(helpful_vote), 2) AS avg_helpful_votes\r\nFROM workspace.default.home_kitchen_reviews_clean_sample\r\nGROUP BY verified_purchase",
        "dimensions": [
          {
            "name": "verified_purchase",
            "expr": "source.verified_purchase",
            "displayName": "Verified Purchase"
          },
          {
            "name": "review_count",
            "expr": "source.review_count",
            "displayName": "Review Count"
          },
          {
            "name": "avg_helpful_votes",
            "expr": "source.avg_helpful_votes",
            "displayName": "Avg Helpful Votes"
          }
        ],
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset. Use this measure to count all",
            "displayName": "Count"
          }
        ]
      }
    },
    {
      "name": "6ef76bca",
      "displayName": "Home & Kitchen -  Review Length Insight",
      "config": {
        "version": "1.1",
        "source": "SELECT\r\n  CASE\r\n    WHEN helpful_vote >= 5 THEN 'Helpful'\r\n    ELSE 'Not Helpful'\r\n  END AS helpful_group,\r\n  COUNT(*) AS review_count,\r\n  ROUND(AVG(review_length), 2) AS avg_review_length,\r\n  ROUND(AVG(rating), 2) AS avg_rating\r\nFROM workspace.default.home_kitchen_reviews_clean_sample\r\nGROUP BY\r\n  CASE\r\n    WHEN helpful_vote >= 5 THEN 'Helpful'\r\n    ELSE 'Not Helpful'\r\n  END",
        "dimensions": [
          {
            "name": "helpful_group",
            "expr": "source.helpful_group",
            "displayName": "Helpful Group"
          },
          {
            "name": "review_count",
            "expr": "source.review_count",
            "displayName": "Review Count"
          },
          {
            "name": "avg_review_length",
            "expr": "source.avg_review_length",
            "displayName": "Avg Review Length"
          },
          {
            "name": "avg_rating",
            "expr": "source.avg_rating",
            "displayName": "Avg Rating"
          }
        ],
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset. Use this measure to count all",
            "displayName": "Count"
          }
        ]
      }
    },
    {
      "name": "bd2adfa0",
      "displayName": "Home & Kitchen -  Rating Distribution",
      "queryLines": [
        "SELECT\r\n",
        "  CAST(rating AS STRING) AS rating_label,\r\n",
        "  COUNT(*) AS review_count\r\n",
        "FROM workspace.default.home_kitchen_reviews_clean_sample\r\n",
        "GROUP BY CAST(rating AS STRING)\r\n",
        "ORDER BY rating_label"
      ]
    },
    {
      "name": "2ea3203e",
      "displayName": "Home Kitchen Monthly Trend",
      "queryLines": [
        "SELECT\r\n",
        "  date_trunc('month', review_time) AS review_month,\r\n",
        "  COUNT(*) AS review_count,\r\n",
        "  ROUND(AVG(rating), 2) AS avg_rating\r\n",
        "FROM workspace.default.home_kitchen_reviews_clean_sample\r\n",
        "GROUP BY date_trunc('month', review_time)\r\n",
        "ORDER BY review_month"
      ]
    }
  ],
